# BeautyBans Environment Variables

# Django Settings
DEBUG=False
SECRET_KEY=change-this-to-random-50-characters-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# URL Prefix (оставить пустым для корня, или указать /beautybans для подкаталога)
# Примеры: "" (корень), "/beautybans", "/bans"
URL_PREFIX=

# PostgreSQL Settings
POSTGRES_DB=beautybans
POSTGRES_USER=beautybans_user
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_PORT=5432

# Nginx Settings
HTTP_PORT=80
