# BeautyBans Environment Variables

# Django Settings
DEBUG=False

# python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-this-to-random-50-characters-without-special-symbols
ALLOWED_HOSTS=localhost,127.0.0.1,YOUR-SERVER-IP

# URL Prefix (оставить пустым для корня, или указать /beautybans для подкаталога)
URL_PREFIX=

# PostgreSQL Settings
POSTGRES_DB=beautybans
POSTGRES_USER=beautybans_user
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_PORT=5432

# Nginx Settings
HTTP_PORT=80
